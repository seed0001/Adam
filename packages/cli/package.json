{
  "name": "@seed0001/adam",
  "version": "0.2.0",
  "description": "Adam — self-hosted autonomous AI agent with persistent memory, web dashboard, and multi-platform adapters",
  "license": "MIT",
  "author": "seed0001",
  "homepage": "https://github.com/seed0001/Adam",
  "repository": {
    "type": "git",
    "url": "https://github.com/seed0001/Adam.git"
  },
  "keywords": ["ai", "agent", "autonomous", "local", "self-hosted", "llm", "discord", "telegram"],
  "type": "module",
  "bin": {
    "adam": "./dist/bin.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "build:publish": "tsup --config tsup.publish.config.ts",
    "prepublishOnly": "pnpm build:publish",
    "dev": "tsup src/bin.ts --format esm --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rimraf dist",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "ai": "^4.3.19",
    "@ai-sdk/anthropic": "^1.2.12",
    "@ai-sdk/openai": "^1.3.24",
    "@ai-sdk/google": "^1.2.22",
    "@ai-sdk/groq": "^1.2.9",
    "@ai-sdk/mistral": "^1.2.8",
    "@ai-sdk/deepseek": "^1.0.34",
    "@openrouter/ai-sdk-provider": "^0.4.6",
    "better-sqlite3": "^11.10.0",
    "drizzle-orm": "^0.40.1",
    "zod": "^3.25.76",
    "neverthrow": "^8.2.0"
  },
  "optionalDependencies": {
    "keytar": "^7.9.0",
    "discord.js": "^14.25.1",
    "grammy": "^1.40.1",
    "@huggingface/transformers": "^3.8.1"
  },
  "devDependencies": {
    "@adam/shared": "workspace:*",
    "@adam/security": "workspace:*",
    "@adam/memory": "workspace:*",
    "@adam/models": "workspace:*",
    "@adam/core": "workspace:*",
    "@adam/skills": "workspace:*",
    "@adam/voice": "workspace:*",
    "@adam/adapters": "workspace:*",
    "@adam/daemon": "workspace:*",
    "commander": "^13.0.0",
    "inquirer": "^12.0.0",
    "chalk": "^5.0.0",
    "ora": "^8.0.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/inquirer": "^9.0.0",
    "@types/node": "^22.0.0",
    "rimraf": "^6.0.0",
    "tsup": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
